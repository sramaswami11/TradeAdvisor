#.env file for TradeAdvisor application
# =========================
# TradeAdvisor Configuration
# =========================




ENABLE_EMAIL=false


MAILJET_API_KEY=
MAILJET_API_SECRET=
EMAIL_FROM=tradeadvisor2025@gmail.com
EMAIL_FROM_NAME=TradeAdvisor
ADMIN_EMAIL=tradeadvisor2025@gmail.com



# Database
# Do NOT set DATABASE_URL locally — app uses SQLite automatically when unset.
# On Render, DATABASE_URL is set via the environment dashboard to the PostgreSQL connection string.

# Rate Limiting
#YFINANCE_RATE_LIMIT=10

# Environment (set to "production" on Render/Heroku)
RENDER=
# or
# FLASK_ENV=production

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn

# Optional: Analytics
# ANALYTICS_ID=your-analytics-id